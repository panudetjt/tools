{
  "name": "color-extractor",
  "version": "1.0.0",
  "description": "Your Figma Plugin",
  "license": "MIT",
  "author": "Panudet <me@panudet.dev>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run build:ui && bun run build:main",
    "build:main": "tsdown",
    "build:ui": "vite build",
    "dev": "concurrently -n vite,tsdown \"vite build --watch\" \"tsdown --watch src/main.ts\"",
    "fix": "ultracite fix",
    "watch": "bun run dev"
  },
  "dependencies": {
    "culori": "^4.0.2"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/culori": "^4.0.1",
    "concurrently": "^9.2.1",
    "oxlint": "^1.58.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
