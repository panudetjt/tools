{
  "name": "color-extractor",
  "version": "1.0.0",
  "description": "Your Figma Plugin",
  "license": "MIT",
  "author": "Panudet <me@panudet.dev>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run build:ui && bun run build:main",
    "build:main": "tsdown --minify",
    "build:ui": "vite build --config vite.config.svelte.ts",
    "build:ui-solid": "vite build --config vite.config.solid.ts",
    "build:ui-react": "vite build --config vite.config.react.ts",
    "build:ui-preact": "vite build --config vite.config.preact.ts",
    "build:ui-preact-compat": "vite build --config vite.config.preact-compat.ts",
    "build:solid": "bun run build:ui-solid && bun run build:main",
    "build:react": "bun run build:ui-react && bun run build:main",
    "build:preact": "bun run build:ui-preact && bun run build:main",
    "build:preact-compat": "bun run build:ui-preact-compat && bun run build:main",
    "dev": "concurrently -n vite,tsdown \"vite build --watch --config vite.config.svelte.ts\" \"tsdown --watch src/main.ts\"",
    "dev:solid": "concurrently -n vite,tsdown \"vite build --watch --config vite.config.solid.ts\" \"tsdown --watch src/main.ts\"",
    "fix": "ultracite fix",
    "watch": "bun run dev"
  },
  "dependencies": {
    "@nanostores/preact": "^1.1.0",
    "culori": "^4.0.2",
    "nanostores": "^1.2.0",
    "react-compiler-runtime": "^1.0.0"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@preact/preset-vite": "^2.10.5",
    "@rolldown/plugin-babel": "^0.2.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/culori": "^4.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "oxlint": "^1.58.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "solid-js": "^1.9.12",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-babel": "^1.6.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vite-plugin-solid": "^2.11.11"
  }
}
