{
  "name": "color-extractor",
  "version": "1.0.0",
  "description": "Your Figma Plugin",
  "license": "MIT",
  "author": "Panudet <me@panudet.dev>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:ui && npm run build:main",
    "build:main": "tsdown",
    "build:ui": "vite build",
    "dev": "concurrently -n vite,tsdown \"vite build --watch\" \"tsdown --watch code.ts\"",
    "lint": "oxlint --config .oxlintrc.json",
    "lint:fix": "oxlint --config .oxlintrc.json --fix",
    "watch": "npm run dev"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "concurrently": "^9.2.1",
    "oxlint": "^1.58.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
