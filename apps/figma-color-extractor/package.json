{
  "name": "color-extractor",
  "version": "1.0.0",
  "private": true,
  "description": "Figma plugin to extract colors from selections and export in multiple formats",
  "license": "MIT",
  "author": "Panudet <me@panudet.dev>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run build:ui && bun run build:main",
    "build:main": "tsdown --minify",
    "build:ui": "vite build",
    "dev": "concurrently -n vite,tsdown \"vite build --watch\" \"tsdown --watch src/main.ts\"",
    "watch": "bun run dev",
    "check-type": "tsc --noEmit"
  },
  "dependencies": {
    "@nanostores/preact": "^1.1.0",
    "culori": "^4.0.2",
    "nanostores": "^1.2.0"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/culori": "^4.0.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
